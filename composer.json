{
  "name": "entelisteam/lbaf-hydrator",
  "description": "Attribute-driven PHP DTO hydrator: builds typed DTOs, enums, nested objects and typed arrays from JSON-like data.",
  "type": "library",
  "license": "MIT",
  "keywords": ["hydrator", "dto", "json", "attribute", "factory", "deserialization"],
  "authors": [
    {
      "name": "ENTELISTEAM INC",
      "email": "welcome@entelis.team",
      "homepage": "https://entelis.team"
    }
  ],
  "require": {
    "php": "~8.2",
    "entelisteam/php-reflection-helpers": "^1.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^12.0",
    "rector/rector": "^2.3.0"
  },
  "autoload": {
    "psr-4": {
      "EntelisTeam\\Lbaf\\Hydrator\\": "src/",
      "EntelisTeam\\Lbaf\\Hydrator\\Rector\\": "rector/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "EntelisTeam\\Lbaf\\Hydrator\\Tests\\": "tests/"
    }
  },
  "extra": {
    "lbaf-rector-migrations": "EntelisTeam\\Lbaf\\Hydrator\\Rector\\Migrations"
  },
  "scripts": {
    "test": "vendor/bin/phpunit"
  },
  "minimum-stability": "stable"
}
